# ─────────────────────────────────────────────────────────────────────────────
#  WebMine BI — Backend Environment Variables
#
#  LOCATION:  This file must be saved as  webmine-project/backend/.env
#             (NOT at the project root, NOT inside app/)
#
#  SETUP:     Copy this file:  copy .env.example .env   (Windows)
#             Then fill in your values below.
#
#  NEVER commit .env to Git — it contains your App Password.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=WebMine BI API
APP_VERSION=1.0.0
DEBUG=false

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default — works with zero setup, file created automatically):
DATABASE_URL=postgresql+psycopg://postgres:EuJc3FGNozkAfjIk@db.xxxxx.supabase.co:5432/postgres?sslmode=require

# MySQL (production — uncomment and fill in): EuJc3FGNozkAfjIk
# DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/webmine

# ── Auth / JWT ─────────────────────────────────────────────────────────────────
# Generate a unique key and paste it here:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-with-secrets-token-hex-32

# ── SMTP Email ─────────────────────────────────────────────────────────────────
#
#  TWO email addresses are involved:
#    SMTP_USER  (below)  = who SENDS  = your Gmail = fixed in this file
#    to_email   (in DB)  = who GETS   = the logged-in user's registered email
#
#  Gmail App Password setup (one-time):
#    1. Enable 2-Factor Authentication at myaccount.google.com/security
#    2. Go to myaccount.google.com/apppasswords
#    3. Choose  App = Mail,  Device = Windows Computer  → Generate
#    4. Copy the 16-character code (e.g. abcd efgh ijkl mnop)
#    5. Paste below WITHOUT spaces: SMTP_PASSWORD=abcdefghijklmnop
#
#  Test without starting the server:
#    cd backend
#    python test_email.py
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASSWORD=paste-your-16-char-app-password-here
EMAIL_FROM=WebMine BI

# ── Upload ─────────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50
